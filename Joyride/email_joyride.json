  "block-1765398547804": {
    "type": "Heading",
    "data": {
      "props": {
        "text": "Bussresa 18 nov",
        "level": "h1"
      },
      "style": {
        "fontFamily": "MODERN_SANS",
        "fontWeight": "bold",
        "textAlign": "center",
        "padding": {
          "top": 16,
          "bottom": 16,
          "right": 24,
